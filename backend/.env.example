NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/skillsphere
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

# ── Email (Nodemailer) ────────────────────────────────────────────────────
# Leave blank in development — the backend auto-provisions a free Ethereal
# test inbox and logs a preview URL for every email sent.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=SkillSphere <no-reply@skillsphere.dev>

# ── File uploads (Cloudinary) ─────────────────────────────────────────────
# Leave blank to fall back to local disk storage under backend/uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Payments (Razorpay test mode) ─────────────────────────────────────────
# Leave blank to use the built-in mock payment gateway (simulates orders /
# captures / refunds without calling Razorpay).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Google OAuth ───────────────────────────────────────────────────────────
# Required for the "Continue with Google" login button to work.
GOOGLE_CLIENT_ID=

# ── AI job matching (Hugging Face, optional) ──────────────────────────────
# Leave blank to use the built-in local skill-similarity scoring fallback.
HUGGINGFACE_API_KEY=
